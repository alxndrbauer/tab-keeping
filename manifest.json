{
  "manifest_version": 2,
  "name": "Tab Keeping",
  "version": "1.1.0",
  "description": "Automatically unload and close inactive tabs in Zen Browser",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "background": {
    "page": "background.html",
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Tab Keeping Settings",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{0ea90491-3d64-417e-b9f2-ca4969d2e8df}",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
